{
  "vault": {
    "path": "/home/sm/wiki/compiled",
    "language": "en",
    "mixed_script": false
  },
  "models": {
    "ingest": "claude-sonnet-4-6",
    "query": "claude-sonnet-4-6",
    "lint": "claude-sonnet-4-6"
  },
  "ingest": {
    "chunk_size_tokens": 2048,
    "overlap_tokens": 128,
    "max_concurrency": 5,
    "formats": [
      "pdf",
      "docx",
      "txt",
      "md",
      "xlsx",
      "csv",
      "pptx"
    ]
  },
  "sync": {
    "interval_minutes": 30,
    "active_hours": {
      "start": "08:00",
      "end": "20:00"
    }
  },
  "lint": {
    "schedule": "weekly",
    "day": "monday",
    "time": "09:00",
    "checks": {
      "orphans": true,
      "contradictions": true,
      "stale_references": true
    }
  },
  "privacy": {
    "telemetry": false,
    "update_check": true
  },
  "ui": {
    "openwebui_port": 3000
  }
}
