{
  "vault": {
    "path": "/home/sm/Repositories/pithhq/vault",
    "language": "en",
    "mixed_script": false
  },
  "models": {
    "ingest": {
      "provider": "ollama",
      "model": "gemma4:latest"
    },
    "query": {
      "provider": "ollama",
      "model": "gemma4:latest"
    },
    "lint": {
      "provider": "ollama",
      "model": "gemma4:latest"
    }
  },
  "providers": {
    "anthropic": {
      "api_key_env": ""
    },
    "ollama": {
      "base_url": "http://localhost:11434"
    }
  },
  "ingest": {
    "chunk_size_tokens": 2048,
    "overlap_tokens": 128,
    "formats": [
      "pdf",
      "docx",
      "txt",
      "md",
      "xlsx",
      "csv",
      "pptx"
    ]
  },
  "sync": {
    "interval_minutes": 30,
    "active_hours": {
      "start": "08:00",
      "end": "20:00"
    }
  },
  "lint": {
    "schedule": "weekly",
    "day": "monday",
    "time": "09:00",
    "checks": {
      "orphans": true,
      "contradictions": true,
      "stale_references": true
    }
  },
  "privacy": {
    "telemetry": false,
    "update_check": true
  },
  "license": {},
  "ui": {
    "openwebui_port": 3000
  }
}
