# PITH — Environment Variables
# Copy this file to .env and fill in your values.
# API keys must NEVER be stored in pith.config.json.

# Anthropic API key (required for ingest)
ANTHROPIC_API_KEY=

# Ollama base URL (defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# PITH license key (written by `pith activate`, not usually set manually)
PITH_LICENSE_KEY=
